# Copy this file to `.env` and fill in your API keys.
# Then `source .env` before running the skill scripts.

# DART OpenAPI (Korean financial disclosures) — REQUIRED for Korean stocks
# Register free at: https://opendart.fss.or.kr/uss/umt/EgovMberInsertView.do
export DART_API_KEY=""

# KRX Open API (Korea Exchange market data) — REQUIRED for Korean stocks
# Register free at: https://openapi.krx.co.kr/
export KRX_API_KEY=""

# SEC EDGAR User-Agent identity — REQUIRED for US stocks
# Format: "Project-Name your.email@example.com"
# No registration needed; SEC requires you identify yourself in the User-Agent header.
export EDGAR_IDENTITY="Your-Project your.email@example.com"

# FRED API (Fed funds, CPI, yields, oil, DXY) — Optional, for Druckenmiller/Dalio/Marks macro analysis
# Register free at: https://fred.stlouisfed.org/docs/api/api_key.html
export FRED_API_KEY=""

# Finnhub free tier (quarterly consensus EPS, earnings calendar) — Optional, for US analysis
# Register free at: https://finnhub.io/register
export FINNHUB_API_KEY=""
